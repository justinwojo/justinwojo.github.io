---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TagList from '../components/TagList.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="mx-auto w-full max-w-4xl flex-1 px-6 py-12">
    <article>
      <header class="mb-10">
        <p class="mb-2 text-sm text-[var(--color-text-muted)]">{formattedDate}</p>
        <h1 class="mb-4 text-3xl font-bold leading-tight text-[var(--color-text)] sm:text-4xl">
          {title}
        </h1>
        <p class="mb-4 text-lg text-[var(--color-text-muted)]">{description}</p>
        <TagList tags={tags} />
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
    <div class="mt-12 border-t border-[var(--color-border)] pt-8">
      <a href="/blog" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
        &larr; Back to all posts
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
