---
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 transition-colors hover:border-[var(--color-accent)]">
  <p class="mb-2 text-sm text-[var(--color-text-muted)]">{formattedDate}</p>
  <h3 class="mb-2 text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
    {title}
  </h3>
  <p class="mb-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{description}</p>
  <TagList tags={tags} linked={false} />
</a>
